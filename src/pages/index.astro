---
import { getCollection } from 'astro:content';
import BaseHead from '../components/common/BaseHead.astro';
import Footer from '../components/common/Footer.astro';
import FormattedDate from '../components/ui/FormattedDate.astro';
import Header from '../components/common/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const RECENT_COUNT = 5;
const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, RECENT_COUNT);
const recentNotes = (await getCollection('notes', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, RECENT_COUNT);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.intro {
				margin-bottom: 4rem;
			}
			.intro h1 {
				margin-top: 0;
			}
			.intro p {
				font-size: 1.15rem;
				color: var(--ink-soft);
				max-width: 34rem;
			}
			.section-label {
				font-family: var(--font-ui);
				font-size: 0.72rem;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--ink-faint);
				margin: 0 0 1.25rem;
			}
			.all-posts {
				display: inline-block;
				margin-top: 1.75rem;
				font-family: var(--font-ui);
				font-size: 0.82rem;
				text-decoration: none;
				color: var(--ink-faint);
			}
			.all-posts:hover {
				color: var(--accent);
			}
			.notes-section {
				margin-top: 3.5rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<h1>{SITE_TITLE}</h1>
				<p>
					{SITE_DESCRIPTION} A place for things I'm learning and experiments I'm
					running — expect the occasional equation, code snippet, and interactive
					chart.
				</p>
			</section>

			<section>
				<p class="section-label">Recent</p>
				<ul class="post-list">
					{
						recentPosts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="title">{post.data.title}</span>
									<span class="date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							</li>
						))
					}
				</ul>
				<a class="all-posts" href="/blog/">All writing &rarr;</a>
			</section>

			{
				recentNotes.length > 0 && (
					<section class="notes-section">
						<p class="section-label">Notes</p>
						<ul class="post-list">
							{recentNotes.map((note) => (
								<li>
									<a href={`/notes/${note.id}/`}>
										<span class="title">{note.data.title}</span>
										<span class="date">
											<FormattedDate date={note.data.pubDate} />
										</span>
									</a>
								</li>
							))}
						</ul>
						<a class="all-posts" href="/notes/">All notes &rarr;</a>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>

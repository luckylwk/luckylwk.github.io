---
import type { MarkdownHeading } from 'astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/common/BaseHead.astro';
import Footer from '../components/common/Footer.astro';
import FormattedDate from '../components/ui/FormattedDate.astro';
import Header from '../components/common/Header.astro';
import PageNav from '../components/common/PageNav.astro';

// `tags`/`draft` carry defaults in the schema, so they're required on the
// collection type — but this layout is also reused by standalone pages (e.g.
// About) that have neither. `draft` is never read here, and `tags` is guarded.
type Props = Omit<CollectionEntry<'blog'>['data'], 'tags' | 'draft'> & {
	tags?: string[];
	headings?: MarkdownHeading[];
};

const { title, description, pubDate, updatedDate, heroImage, tags, headings } =
	Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			/* `main` already carries the reading measure and the page gutter;
			   fill it rather than subtracting the gutter a second time. */
			article {
				width: 100%;
				margin: 0 auto;
			}
			.header {
				margin-bottom: 2.5rem;
			}
			.meta {
				font-family: var(--font-ui);
				font-size: 0.78rem;
				letter-spacing: 0.02em;
				color: var(--ink-faint);
				margin: 0 0 1rem;
			}
			.last-updated-on {
				color: var(--ink-faint);
			}
			.header h1 {
				margin: 0 0 1rem;
				font-size: 2.4rem;
				line-height: 1.15;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.9rem;
				margin: 1.25rem 0 0;
				padding: 0;
				list-style: none;
			}
			.tags li {
				font-family: var(--font-ui);
				font-size: 0.78rem;
				color: var(--ink-faint);
			}
			.hero-image {
				margin: 0 0 2.5rem;
			}
			.hero-image img {
				display: block;
				width: 100%;
				border-radius: 4px;
			}
			.divider {
				margin: 1.75rem 0 0;
			}
		</style>
	</head>

	<body>
		<Header />
		{headings && <PageNav headings={headings} />}
		<main>
			<article>
				<div class="header">
					<p class="meta">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="last-updated-on">
									· updated <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</p>
					<h1>{title}</h1>
					{
						tags && tags.length > 0 && (
							<ul class="tags">
								{tags.map((tag) => (
									<li>#{tag}</li>
								))}
							</ul>
						)
					}
					<hr class="divider" />
				</div>
				{
					heroImage && (
						<div class="hero-image">
							<Image width={1020} height={510} src={heroImage} alt="" />
						</div>
					)
				}
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

---
import { SITE_AUTHOR } from '../../consts';
const today = new Date();
---

<footer>
	<span>&copy; {today.getFullYear()} {SITE_AUTHOR}</span>
	<span class="social">
		<a href="https://github.com/luckylwk" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
			<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
				<path
					d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58l-.01-2.05c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02 0 2.05.14 3 .4 2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22l-.01 3.29c0 .32.22.7.83.58C20.56 22.3 24 17.8 24 12.5 24 5.87 18.63.5 12 .5Z"
				></path>
			</svg>
		</a>
		<a href="https://x.com/luckylwk" target="_blank" rel="noopener noreferrer" aria-label="X">
			<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
				<path
					d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"
				></path>
			</svg>
		</a>
	</span>
</footer>
<style>
	footer {
		width: var(--measure);
		max-width: calc(100% - 2.5rem);
		margin: 0 auto;
		padding: 2rem 0 3rem;
		border-top: 1px solid var(--rule);
		font-family: var(--font-ui);
		font-size: 0.78rem;
		letter-spacing: 0.02em;
		color: var(--ink-faint);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.social {
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.social a {
		display: inline-flex;
		color: var(--ink-faint);
		text-decoration: none;
		transition: color 0.15s ease;
	}
	.social a:hover {
		color: var(--accent);
	}
</style>

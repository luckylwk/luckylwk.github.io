---
import type { MarkdownHeading } from 'astro';

type Props = {
	headings: MarkdownHeading[];
};

const { headings } = Astro.props;
// Only H2/H3 make useful section anchors; deeper levels add noise.
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
	items.length > 1 && (
		<nav class="page-nav" aria-label="On this page">
			<ul>
				{items.map((h) => (
					<li class:list={[`level-${h.depth}`]}>
						<a href={`#${h.slug}`}>{h.text}</a>
					</li>
				))}
			</ul>
		</nav>
	)
}

<style>
	/* Floats in the left gutter beside the centred reading column. Fixed so it
	   stays in view as a persistent orientation aid while scrolling. */
	.page-nav {
		position: fixed;
		top: 12rem;
		left: 2.5rem;
		width: 11rem;
		max-height: calc(100vh - 16rem);
		overflow-y: auto;
	}
	.page-nav ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.page-nav li {
		margin: 0 0 0.75rem;
		line-height: 1.1;
	}
	.page-nav .level-3 {
		padding-left: 0.9rem;
	}
	.page-nav a {
		font-family: var(--font-ui);
		font-size: 0.675rem;
		color: var(--ink-faint);
		text-decoration: none;
	}
	.page-nav a:hover {
		color: var(--accent);
	}

	/* No room for the gutter nav on narrower viewports — hide it. */
	@media (max-width: 1100px) {
		.page-nav {
			display: none;
		}
	}
</style>

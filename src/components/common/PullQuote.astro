---
// A distinct pull-quote — larger and more emphatic than the default inline
// blockquote. Warm-paper card with an oversized decorative quote glyph. The
// quote text is the default slot; attribution is handled by dropping an inline
// <Cite /> marker at the end of the quote, so it flows into the post's shared
// References appendix rather than a standalone link.
---

<figure class="pull-quote">
	<blockquote>
		<slot />
	</blockquote>
</figure>

<style>
	.pull-quote {
		position: relative;
		margin: 2.75rem 0;
		padding: 2rem 2.25rem 1.75rem;
		background: var(--paper-card);
		border: 1px solid var(--rule);
		border-radius: 4px;
	}
	/* Oversized decorative opening quote mark, tucked into the top-left. */
	.pull-quote::before {
		content: '\201C';
		position: absolute;
		top: 0.35rem;
		left: 0.9rem;
		font-family: Georgia, serif;
		font-size: 3.75rem;
		line-height: 1;
		color: var(--accent);
		opacity: 0.28;
		pointer-events: none;
	}
	.pull-quote blockquote {
		/* Reset the global blockquote treatment — this card owns the styling. */
		border: none;
		margin: 0;
		padding: 0;
		font-style: normal;
		font-size: 1.3rem;
		line-height: 1.55;
		font-weight: 500;
		letter-spacing: -0.01em;
		color: var(--ink);
	}
	@media (max-width: 640px) {
		.pull-quote {
			padding: 1.6rem 1.4rem 1.4rem;
		}
		.pull-quote blockquote {
			font-size: 1.15rem;
		}
	}
</style>
